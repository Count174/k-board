NODE_ENV=production

# --- Telegram ---
BOT_TOKEN=
CHAT_ID=
TELEGRAM_BOT_ENABLED=true
TELEGRAM_USE_POLLING=false
TELEGRAM_WEBHOOK_BASE_URL=https://o-board.ru
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# --- CEO-панель ---
CEO_TELEGRAM_BOT_TOKEN=
CEO_TELEGRAM_CHAT_ID=
CEO_SECRET=

# --- WHOOP ---
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_SCOPES=offline
WHOOP_REDIRECT_URI=https://o-board.ru/api/whoop/callback
WHOOP_SUCCESS_REDIRECT=https://o-board.ru/app/health
WHOOP_FAIL_REDIRECT=https://o-board.ru/app/health?whoop=error

# --- Auth / JWT ---
JWT_SECRET=                  # openssl rand -hex 32
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_MS=2592000000
SESSION_SECRET=              # openssl rand -hex 16

# --- Frontend ---
FRONTEND_URL=https://o-board.ru

# --- APNs (опционально) ---
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_ENV=production

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# --- Moving ---
MOVING_LOGIN=
MOVING_PASSWORD=
MOVING_SESSION_SECRET=
